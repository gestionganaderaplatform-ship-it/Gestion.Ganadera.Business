{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AppDb_Business;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Database": {
    "ForceAutoMigrate": true
  },
  "AuthApi": {
    "BaseUrl": "https://localhost:7191"
  },
  "Jwt": {
    "SigningKey": "CLAVE_DESARROLLO_TEMPORAL_MINIMO_32_CHARS",
    "Enabled": true,
    "Issuer": "Gestion.Ganadera.Business.Auth.API",
    "Audience": "Gestion.Ganadera.Business.Auth.Clients"
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "ForwardLimit": 1,
    "RequireHeaderSymmetry": true,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Cors": {
    "Enabled": true,
    "PolicyName": "DefaultCorsPolicy",
    "AllowedOrigins": [
      "http://localhost:4200"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Correlation-Id", "X-Requested-With" ],
    "AllowCredentials": false
  },
  "AutoMapper": {
    "LicenseKey": ""
  }
}
