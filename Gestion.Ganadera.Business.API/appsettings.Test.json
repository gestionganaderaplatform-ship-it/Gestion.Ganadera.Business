{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Jwt": {
    "Enabled": true
  },
  "AuthApi": {
    "BaseUrl": "https://app-gga-auth-test.azurewebsites.net"
  },
  "Cors": {
    "Enabled": true,
    "PolicyName": "DefaultCorsPolicy",
    "AllowedOrigins": [
      "https://app-gga-web-test.azurewebsites.net",
      "http://localhost:4200"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Correlation-Id", "X-Requested-With" ],
    "AllowCredentials": false
  }
}
