{

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": ""

  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  },

  "RateLimiting": {
    "Global": {
      "Enabled": true,
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },

  "Security": {
    "EnableSecurityHeaders": true,
    "HstsDays": 365
  },
  "ApiInfo": {
    "Codigo": "Gestion.Ganadera.API"
  },
  "ExcelImport": {
    "MaxRowsPerImport": 500
  },
  "Jwt": {
    "Enabled": false,
    "Issuer": "Gestion.Ganadera.API",
    "Audience": "Gestion.Ganadera.Clients",
    "SigningKey": ""
  },
  "Cors": {
    "Enabled": true,
    "PolicyName": "DefaultCorsPolicy",
    "AllowedOrigins": [
      "http://localhost:4200"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Correlation-Id" ],
    "AllowCredentials": false
  },
  "AutoMapper": {
    "LicenseKey": ""
  }

}
